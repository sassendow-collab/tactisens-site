---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tarifs Escape Game Toulouse | Tactisens" description="Tarifs de nos escape games à Toulouse. Aventure Sensorielle et The Bunker, à partir de 29€ par personne.">

  <!-- ==================== SECTION 1 : HERO COMPACT ==================== -->
  <section class="relative py-16 lg:py-20 bg-tac-dark-blue">
    <img
      src="/images/escape-game-toulouse-tactisens-04.webp"
      alt="Tarifs Escape Game Toulouse Tactisens"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-tac-dark-blue/70"></div>
    <div class="relative z-10 section-content pt-[120px]">
      <h1 class="font-share text-colossal lg:text-gigantic text-tac-white font-bold leading-none tracking-[-2px]">
        Tarifs
      </h1>
      <nav class="mt-4 text-sm text-white/60" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white no-underline text-white/60">Accueil</a>
        <span class="mx-2">/</span>
        <span class="text-white/80">Tarifs</span>
      </nav>
    </div>
  </section>

  <!-- ==================== SECTION 2 : PRICING INFO ==================== -->
  <section class="bg-tac-dark-blue py-16 lg:py-24">
    <div class="section-content">

      <!-- Spirale + H2 bicolore -->
      <div class="flex items-start gap-0 mb-12">
        <img
          src="/images/escape-game-toulouse-tactisens-31.webp"
          alt="Tactisens"
          class="w-[49px] h-[50px] shrink-0"
        />
        <h2 class="pl-5 font-share text-[2.5rem] lg:text-colossal font-bold tracking-[-2px] leading-none">
          <span class="text-tac-white">Tarifs</span><br>
          <span class="text-tac-orange">Escape Games Toulouse</span>
        </h2>
      </div>

      <!-- Two columns -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- LEFT: Info text -->
        <div>
          <p class="font-share text-bigger uppercase text-tac-orange leading-snug mb-6">
            Pour réserver des créneaux, il est nécessaire d'effectuer le paiement en ligne à l'avance.
          </p>
          <p class="font-mulish text-tac-white/80 text-body leading-relaxed mb-4">
            Si vous avez des questions, vous pouvez consulter nos <a href="/faq/" class="text-tac-orange hover:underline">FAQ</a>.
          </p>
          <p class="font-mulish text-tac-white/80 text-body leading-relaxed">
            Impossible de payer pour toute l'équipe ? Partagez le paiement !
          </p>
        </div>

        <!-- RIGHT: Moyens de paiement card -->
        <div class="border-2 border-tac-orange p-8">
          <h3 class="font-share text-bigger uppercase text-tac-orange tracking-[2px] mb-6">
            Moyens de paiement
          </h3>
          <div class="flex flex-wrap items-center gap-6">
            <span class="font-mulish text-tac-white/80 text-body">Mastercard</span>
            <span class="font-mulish text-tac-white/80 text-body">Visa</span>
            <span class="font-mulish text-tac-white/80 text-body">CB</span>
            <span class="font-mulish text-tac-white/80 text-body">Chèques vacances</span>
            <span class="font-mulish text-tac-white/80 text-body">ANCV</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ==================== SECTION 3 : PRICING CARDS ==================== -->
  <section class="bg-tac-dark-blue py-16 lg:py-24">
    <div class="section-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- LEFT: L'Aventure Sensorielle -->
        <div>
          <h3 class="font-share text-larger lg:text-colossal text-tac-white font-bold uppercase leading-tight mb-8">
            L'Aventure Sensorielle
          </h3>

          <div class="space-y-4 mb-8">
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 3 joueurs</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">39 € par personne</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 4 joueurs</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">32 € par personne</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 5 joueurs et +</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">29 € par personne</span>
            </div>
          </div>

          <div class="space-y-3 mb-10">
            <p class="font-mulish text-tac-white/80 text-body">
              Durée du jeu : <span class="text-tac-orange font-bold">1h15 maximum</span> (+ le briefing et le débriefing)
            </p>
            <p class="font-mulish text-tac-white/80 text-body">
              Temps sur place : <span class="text-tac-orange font-bold">entre 1h30 et 1h45</span> environ
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/reservation/" class="btn-orange text-center">Réserver</a>
            <a href="/carte-cadeau/" class="btn-outline-orange text-center">Offrir un bon cadeau</a>
          </div>
        </div>

        <!-- RIGHT: The Bunker -->
        <div>
          <h3 class="font-share text-larger lg:text-colossal text-tac-white font-bold uppercase leading-tight mb-8">
            The Bunker <span class="block text-bigger text-tac-white/60 normal-case mt-1">(Escape Room)</span>
          </h3>

          <div class="space-y-4 mb-8">
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 2 joueurs</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">45 € par personne</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 3 joueurs</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">39 € par personne</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 4 joueurs</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">32 € par personne</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-white/10 pb-3">
              <span class="font-mulish text-tac-white text-body">Equipe de 5 joueurs et +</span>
              <span class="font-share text-big text-tac-orange font-bold whitespace-nowrap">29 € par personne</span>
            </div>
          </div>

          <div class="space-y-3 mb-10">
            <p class="font-mulish text-tac-white/80 text-body">
              Durée du jeu : <span class="text-tac-orange font-bold">1h maximum</span> (+ le briefing et le débriefing)
            </p>
            <p class="font-mulish text-tac-white/80 text-body">
              Temps sur place : <span class="text-tac-orange font-bold">1h30</span> environ
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/reservation/" class="btn-orange text-center">Réserver</a>
            <a href="/carte-cadeau/" class="btn-outline-orange text-center">Offrir un bon cadeau</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ==================== SECTION 4 : DEMANDEZ UN DEVIS ==================== -->
  <section class="relative bg-tac-dark-blue py-16 lg:py-24">
    <img
      src="/images/escape-game-toulouse-tactisens-04.webp"
      alt="Escape Game Toulouse"
      class="absolute inset-0 w-full h-full object-cover opacity-10"
    />
    <div class="absolute inset-0 bg-tac-dark-blue/80"></div>
    <div class="relative z-10 section-content">
      <div class="flex items-start gap-0 mb-8">
        <img
          src="/images/escape-game-toulouse-tactisens-31.webp"
          alt="Tactisens"
          class="w-[49px] h-[50px] shrink-0"
        />
        <h2 class="pl-5 font-share text-[2.5rem] lg:text-colossal font-bold tracking-[-2px] leading-none">
          <span class="text-tac-white">Demandez</span><br>
          <span class="text-tac-orange">un devis</span>
        </h2>
      </div>
      <p class="font-mulish text-tac-white/80 text-big leading-relaxed mb-8 max-w-2xl">
        Vous êtes un groupe de plus de 6 personnes, une entreprise, un CE ou une association ? Contactez-nous pour obtenir un devis personnalisé avec des tarifs adaptés.
      </p>
      <a href="/contact/" class="btn-orange">Nous contacter</a>
    </div>
  </section>

  <!-- ==================== SECTION 5 : POUR S'ÉVADER ==================== -->
  <section class="bg-tac-white py-16 lg:py-24">
    <div class="section-content">

      <!-- Spirale + H2 -->
      <div class="flex items-start gap-0 mb-12">
        <img
          src="/images/escape-game-toulouse-tactisens-31.webp"
          alt="Tactisens"
          class="w-[49px] h-[50px] shrink-0"
        />
        <h2 class="pl-5 font-share text-[2.5rem] lg:text-colossal font-bold tracking-[-2px] leading-none">
          <span class="text-tac-orange">Pour s'évader</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- LEFT: Reservation + Address -->
        <div>
          <h5 class="font-share text-bigger uppercase text-tac-orange tracking-[2px] mb-4">
            Uniquement sur réservation
          </h5>
          <p class="font-mulish text-tac-gray text-body leading-relaxed mb-2">
            33 Port Saint-Sauveur<br>
            31000 Toulouse
          </p>
          <p class="font-mulish text-tac-gray/70 text-sm mb-8">
            (A côté du Grand Rond et de la Place Dupuy)
          </p>

          <h5 class="font-share text-bigger uppercase text-tac-orange tracking-[2px] mb-4">
            Horaires d'ouverture
          </h5>
          <div class="font-mulish text-tac-gray text-body space-y-1 mb-8">
            <p>Lundi au Jeudi : 10h - 23h30</p>
            <p>Vendredi : 10h - 00h30</p>
            <p>Samedi : 9h - 00h30</p>
            <p>Dimanche : 10h - 23h</p>
          </div>

          <h5 class="font-share text-bigger uppercase text-tac-orange tracking-[2px] mb-4">
            Itinéraire
          </h5>
          <p class="font-mulish text-tac-gray text-body leading-relaxed mb-2">
            <a href="https://www.google.com/maps/dir//Tactisens+Escape+Game+Toulouse" target="_blank" rel="noopener" class="text-tac-orange hover:underline">
              Ouvrir dans Google Maps
            </a>
          </p>

          <h5 class="font-share text-bigger uppercase text-tac-orange tracking-[2px] mt-8 mb-4">
            Autres accès
          </h5>
          <div class="font-mulish text-tac-gray text-body space-y-2">
            <p>Métro : François Verdier (5 min à pied)</p>
            <p>Bus : Lignes 14, 22, 27, 38, L1</p>
            <p>VéloToulouse : Station à 2 min</p>
            <p>Parking devant le local (dont 2 places PMR)</p>
            <p>Parking Paul Sabatier (2 min à pied)</p>
            <p>Parking Carnot (5 min à pied)</p>
          </div>
        </div>

        <!-- RIGHT: Map image -->
        <div>
          <a href="https://www.google.com/maps/dir//Tactisens+Escape+Game+Toulouse" target="_blank" rel="noopener">
            <img
              src="/images/escape-game-toulouse-tactisens-plan-contact.webp"
              alt="Plan d'accès Tactisens Escape Game Toulouse"
              class="w-full hover:opacity-90 transition-opacity"
              loading="lazy"
            />
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>
