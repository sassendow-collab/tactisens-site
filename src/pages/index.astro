---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Escape Game Toulouse. Jeu d'evasion Sensoriel | Tactisens">

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[100dvh] flex items-center justify-center text-center overflow-hidden bg-cover bg-center" id="hero" style="background-image: url('/images/escape-game-toulouse-tactisens-01.webp');">
    <div class="absolute inset-0 bg-gradient-to-b from-tac-dark-blue/60 via-black/40 to-black/70"></div>

    <div class="relative z-10 px-5 max-w-[1420px] mx-auto">
      <img
        src="/images/escape-game-toulouse-tactisens.webp"
        alt="Icônes des sens du logo Tactisens Escape Game Toulouse"
        class="w-[100px] h-[100px] lg:w-[130px] lg:h-[130px] mx-auto mb-8 hero-fade"
        style="animation-delay: 0.1s;"
      />
      <h1 class="font-share text-[0.95rem] lg:text-[1.15rem] font-bold text-tac-orange uppercase tracking-[5px] lg:tracking-[8px] mb-4 hero-fade" style="animation-delay: 0.25s;">
        Escape Game Toulouse
      </h1>
      <h2 class="font-share text-[2rem] sm:text-[2.6rem] lg:text-colossal font-bold text-white leading-[1.08] tracking-[-1px] lg:tracking-[-2px] mb-5 hero-fade" style="animation-delay: 0.45s; text-shadow: 0 4px 40px rgba(0,0,0,0.6);">
        Vivez une aventure<br>captivante et unique !
      </h2>
      <p class="font-mulish text-[0.95rem] lg:text-body font-normal text-white/70 mb-8 hero-fade" style="animation-delay: 0.55s;">
        Plus qu'un Escape Game, un divertissement original a partager entre amis, entre collegues, en famille.
      </p>
      <a href="/reservation/" class="btn-outline-white hero-fade" style="animation-delay: 0.65s;">réservez votre aventure !</a>
    </div>
  </section>

  <!-- ==================== STATS BAR ==================== -->
  <section class="relative bg-tac-dark-blue overflow-hidden">
    <div class="h-[2px] bg-gradient-to-r from-transparent via-tac-orange to-transparent"></div>

    <div class="section-content py-6 lg:py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-0">
        <div class="relative py-4 px-3 text-center group reveal-up opacity-0" style="--delay: 0.1s;">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 h-[50%] w-[1px] bg-white/15"></div>
          <img src="/images/escape-game-toulouse-tactisens-15.webp" alt="Escape Game Toulouse âge minimum" class="w-[36px] h-[39px] mx-auto mb-2" />
          <p class="font-share text-[0.8rem] font-normal leading-tight text-white/50">de</p>
          <p class="font-share text-big font-bold leading-tight">7 à 97 ans</p>
        </div>
        <div class="relative py-4 px-3 text-center group reveal-up opacity-0" style="--delay: 0.2s;">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 h-[50%] w-[1px] bg-white/15 hidden lg:block"></div>
          <img src="/images/escape-game-toulouse-tactisens-16.webp" alt="Escape Game Toulouse, participants maximums" class="w-[40px] h-[39px] mx-auto mb-2" />
          <p class="font-share text-[0.8rem] font-normal leading-tight text-white/50">de</p>
          <p class="font-share text-big font-bold leading-tight whitespace-nowrap">2 à 72 joueurs</p>
        </div>
        <div class="relative py-4 px-3 text-center group reveal-up opacity-0" style="--delay: 0.3s;">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 h-[50%] w-[1px] bg-white/15"></div>
          <img src="/images/escape-game-toulouse-tactisens-18.webp" alt="Escape Game Toulouse, prix tarifs" class="w-[40px] h-[39px] mx-auto mb-2" />
          <p class="font-share text-[0.8rem] font-normal leading-tight text-white/50">à partir de</p>
          <p class="font-share text-big font-bold leading-tight whitespace-nowrap">29 &euro;</p>
        </div>
        <div class="relative py-4 px-3 text-center group reveal-up opacity-0" style="--delay: 0.4s;">
          <img src="/images/escape-game-toulouse-tactisens-17.webp" alt="Escape Game Toulouse, recommandations Tripadvisor" class="w-[50px] h-[39px] mx-auto mb-2" />
          <p class="font-share text-[0.8rem] font-normal leading-tight text-white/50">Travellers'</p>
          <p class="font-share text-big font-bold leading-tight">Choice</p>
        </div>
      </div>
    </div>

    <div class="h-[2px] bg-gradient-to-r from-transparent via-tac-orange to-transparent"></div>
  </section>

  <!-- Spacer -->
  <div class="h-16 lg:h-24 bg-tac-black"></div>

  <!-- ==================== MISSIONS ==================== -->
  <section class="relative overflow-hidden bg-cover bg-center bg-fixed" style="background-image: url('/images/escape-game-toulouse-tactisens-03.webp');">
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative z-10 section-content py-20 lg:py-28">
      <!-- Section header -->
      <div class="flex items-center gap-4 mb-4 reveal-left opacity-0">
        <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Escape Game Toulouse les missions" class="w-[42px] h-[43px] shrink-0" />
        <h2 class="font-share text-large lg:text-larger font-bold tracking-[-2px] leading-none">
          <span class="text-white">Les </span>
          <span class="text-tac-orange">missions</span>
        </h2>
      </div>
      <p class="font-mulish text-body lg:text-big font-normal leading-relaxed mb-10 lg:mb-14 max-w-[780px] reveal-up opacity-0 text-white/85">
        Tactisens Escape Game Toulouse vous propose des Escape Room originaux, funs et immersifs pour vous faire vivre un moment palpitant et unique&nbsp;!
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14">
        <!-- L'AVENTURE SENSORIELLE -->
        <div class="mission-card group relative bg-black/40 backdrop-blur-sm border border-white/10 overflow-hidden reveal-up opacity-0 transition-all duration-500 hover:border-tac-orange/60" style="--delay: 0.1s;">
          <!-- Image with overlay -->
          <div class="relative overflow-hidden">
            <img src="/images/Laventure-sensorielle-Escape-game-a-Toulouse.png" alt="" class="w-full aspect-[16/10] object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <!-- Floating title on image -->
            <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
              <h3 class="font-share text-[1.3rem] lg:text-[1.65rem] font-bold leading-none text-white mb-1">L'AVENTURE SENSORIELLE</h3>
              <p class="font-share text-[0.75rem] uppercase text-tac-orange tracking-[2px]">un défi lancé à vos sens</p>
            </div>
          </div>

          <div class="p-6 lg:p-8">
            <!-- Stats row -->
            <div class="flex flex-wrap justify-between items-center gap-4 text-sm py-4 border-b border-white/10">
              <div class="flex items-center gap-2">
                <img src="/images/escape-game-toulouse-tactisens-16.webp" alt="Escape Game Toulouse, participants maximums" class="w-9 h-9 opacity-80" />
                <span class="font-mulish font-semibold leading-tight text-white/90">3 à 12<br>joueurs </span>
              </div>
              <div class="flex items-center gap-2">
                <img src="/images/escape-game-toulouse-tactisens-19.webp" alt="Escape Game Toulouse durée" class="w-9 h-9 opacity-80" />
                <span class="font-mulish font-semibold leading-tight text-white/90">60 <br>minutes</span>
              </div>
              <div class="flex items-center gap-2">
                <img src="/images/escape-game-toulouse-tactisens-15.webp" alt="Escape Game Toulouse âge minimum" class="w-9 h-9 opacity-80" />
                <span class="font-mulish font-semibold leading-tight text-white/90">de 7 à 97<br>ans</span>
              </div>
            </div>

            <!-- Difficulty -->
            <div class="flex flex-wrap items-center gap-3 text-sm py-4 border-b border-white/10">
              <span class="font-share font-bold text-tac-orange uppercase tracking-wider text-[0.8rem]">niveau de difficulté :</span>
              <span class="flex items-center gap-1 font-mulish font-semibold text-white/80">
                <img src="/images/true.svg" alt="" class="w-3 h-3" />
                Adapaté aux familles
              </span>
              <span class="flex items-center gap-1 font-mulish font-semibold text-white/80">
                <img src="/images/true.svg" alt="" class="w-3 h-3" />
                Adaptable selon le niveau des joueurs
              </span>
            </div>

            <p class="font-mulish text-sm font-semibold leading-relaxed text-white/75 py-5">Vous serez les cobayes du protocole de test sur les sens élaboré par le Dr Windar.<br><br>Dans des situations insolites et amusantes, vos 5 sens seront les héros de ce périple inédit : la vue, le toucher, le goût, l'ouïe et l'odorat seront mis à rude épreuve.</p>

            <div class="flex flex-wrap gap-3 pt-2">
              <a href="/reservation/" class="btn-orange flex-1 min-w-[160px] text-center !text-[1.05rem] !py-3.5">réserver</a>
              <a href="/mission/escape-game-original-aventure-sensorielle/" class="btn-outline-orange flex-1 min-w-[160px] text-center !text-[1.05rem] !py-3.5">en savoir plus</a>
            </div>
          </div>
        </div>

        <!-- THE BUNKER -->
        <div class="mission-card group relative bg-black/40 backdrop-blur-sm border border-white/10 overflow-hidden reveal-up opacity-0 transition-all duration-500 hover:border-tac-orange/60" style="--delay: 0.25s;">
          <!-- Image with overlay -->
          <div class="relative overflow-hidden">
            <img src="/images/The-Bunker-Escape-game-a-Toulouse.png" alt="" class="w-full aspect-[16/10] object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
              <h3 class="font-share text-[1.3rem] lg:text-[1.65rem] font-bold leading-none text-white mb-1">THE BUNKER</h3>
              <p class="font-share text-[0.75rem] uppercase text-tac-orange tracking-[2px]">escape room</p>
            </div>
          </div>

          <div class="p-6 lg:p-8">
            <div class="flex flex-wrap justify-between items-center gap-4 text-sm py-4 border-b border-white/10">
              <div class="flex items-center gap-2">
                <img src="/images/escape-game-toulouse-tactisens-16.webp" alt="Escape Game Toulouse, participants maximums" class="w-9 h-9 opacity-80" />
                <span class="font-mulish font-semibold leading-tight text-white/90">2 à 6 joueurs</span>
              </div>
              <div class="flex items-center gap-2">
                <img src="/images/escape-game-toulouse-tactisens-19.webp" alt="Escape Game Toulouse durée" class="w-9 h-9 opacity-80" />
                <span class="font-mulish font-semibold leading-tight text-white/90">60<br>minutes</span>
              </div>
              <div class="flex items-center gap-2">
                <img src="/images/escape-game-toulouse-tactisens-15.webp" alt="Escape Game Toulouse âge minimum" class="w-9 h-9 opacity-80" />
                <span class="font-mulish font-semibold leading-tight text-white/90">de 10 à 97<br>ans</span>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 text-sm py-4 border-b border-white/10">
              <span class="font-share font-bold text-tac-orange uppercase tracking-wider text-[0.8rem]">niveau de difficulté :</span>
              <span class="flex items-center gap-1 font-mulish font-semibold text-white/80">
                <img src="/images/true.svg" alt="" class="w-3 h-3" />
                6/10
              </span>
              <span class="flex items-center gap-1 font-mulish font-semibold text-white/80">
                <img src="/images/true.svg" alt="" class="w-3 h-3" />
                Adaptable selon le niveau des joueurs
              </span>
            </div>

            <p class="font-mulish text-sm font-semibold leading-relaxed text-white/75 py-5">Oserez-vous pénétrer dans le bunker désaffecté où s'est réfugié le Dr Windar pour protéger ses recherches sur la vie éternelle ? <br><br>Déjouez les pièges, retrouvez les pistes et récupérez ses recherches pour sauver l'humanité. Adrénaline, amusement et sollicitation cérébrale.</p>

            <div class="flex flex-wrap gap-3 pt-2">
              <a href="/reservation/" class="btn-orange flex-1 min-w-[160px] text-center !text-[1.05rem] !py-3.5">réserver</a>
              <a href="/mission/escape-room-toulouse/" class="btn-outline-orange flex-1 min-w-[160px] text-center !text-[1.05rem] !py-3.5">en savoir plus</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== VIDEO CTA ==================== -->
  <div class="bg-tac-black py-12 lg:py-20">
    <div class="h-[2px] bg-gradient-to-r from-transparent via-tac-orange to-transparent"></div>
  </div>
  <section class="bg-tac-black">
    <div class="section-content py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="relative pb-[56.25%] h-0 overflow-hidden rounded-lg reveal-up opacity-0 shadow-2xl shadow-black/50">
          <iframe class="absolute top-0 left-0 w-full h-full" src="https://www.youtube.com/embed/8s0mPKsrfKA" title="Tactisens Escape Game Toulouse" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="lg:pl-8 reveal-right opacity-0">
          <div class="flex items-start gap-4">
            <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Tactisens Escape Game Toulouse" class="w-[42px] h-[43px] shrink-0 mt-1" />
            <h2 class="font-share text-[1.5rem] sm:text-large lg:text-larger font-bold tracking-[-1px] leading-[1.1]">
              <span class="text-white">Tactisens</span><br />
              <span class="text-white">Escape Game Toulouse :</span><br />
              <span class="text-tac-orange">Quel sera votre défi ?</span>
            </h2>
          </div>
        </div>
      </div>
      <div class="text-center mt-10 reveal-up opacity-0">
        <a href="/reservation/" class="btn-outline-orange">Réservez votre aventure !</a>
      </div>
    </div>
  </section>
  <div class="bg-tac-black py-12 lg:py-20">
    <div class="h-[2px] bg-gradient-to-r from-transparent via-tac-orange to-transparent"></div>
  </div>

  <!-- ==================== EVENEMENTS ==================== -->
  <section class="relative overflow-hidden bg-cover bg-center bg-fixed" style="background-image: url('/images/escape-game-toulouse-tactisens-05.webp');">
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative z-10 section-content py-16 lg:py-24">
      <div class="flex items-start gap-4 mb-12 reveal-left opacity-0">
        <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Tactisens Escape Game Toulouse évènements" class="w-[42px] h-[43px] shrink-0 mt-1" />
        <h2 class="font-share text-large lg:text-larger font-bold tracking-[-2px] leading-none">
          <span class="text-white">Tactisens pour vos <br></span>
          <span class="text-tac-orange">évènements à Toulouse</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Entreprises -->
        <div class="group reveal-up opacity-0 border border-white/10 bg-black/30 backdrop-blur-sm overflow-hidden transition-all duration-500 hover:border-tac-orange/50" style="--delay: 0.1s;">
          <div class="relative overflow-hidden">
            <img src="/images/escape-game-toulouse-team-building.webp" alt="Team building à Tactisens Escape Game Toulouse" class="w-full aspect-[3/2] object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <h3 class="absolute bottom-4 left-5 right-5 font-share text-[1.1rem] font-bold text-white leading-tight">Escape Game pour Entreprises a&nbsp;Toulouse</h3>
          </div>
          <div class="p-5">
            <p class="font-mulish text-[0.8rem] font-semibold leading-normal text-white/65 mb-4">Cohesion d'equipe, activites ludiques, <a href="/location-de-salle-a-toulouse/" class="text-tac-orange underline">salle de reunion</a>, cocktails et plus encore&nbsp;!</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <a href="/evenement/entreprises/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">Team building</a>
              <a href="/escape-game-recrutement/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">Recrutement</a>
              <a href="/escape-game-ce-cse/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">CE / CSE</a>
            </div>
            <a href="/evenement/entreprises/" class="inline-block font-share text-[0.85rem] font-bold tracking-wider uppercase text-tac-orange hover:text-white transition-colors">
              decouvrir les offres &rarr;
            </a>
          </div>
        </div>

        <!-- Particuliers -->
        <div class="group reveal-up opacity-0 border border-white/10 bg-black/30 backdrop-blur-sm overflow-hidden transition-all duration-500 hover:border-tac-orange/50" style="--delay: 0.2s;">
          <div class="relative overflow-hidden">
            <img src="/images/escape-game-toulouse-particuliers.webp" alt="Escape Game à Toulouse équipe Tactisens" class="w-full aspect-[3/2] object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <h3 class="absolute bottom-4 left-5 right-5 font-share text-[1.1rem] font-bold text-white leading-tight">Escape Game pour particuliers a Toulouse</h3>
          </div>
          <div class="p-5">
            <p class="font-mulish text-[0.8rem] font-semibold leading-normal text-white/65 mb-4">Entre amis ou en famille, une sortie originale et decalee a ne pas rater !</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <a href="/evjf-toulouse/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">EVJF</a>
              <a href="/evg-toulouse/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">EVG</a>
              <a href="/anniversaire-original-toulouse/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">Anniversaire</a>
            </div>
            <a href="/evenement/particuliers/" class="inline-block font-share text-[0.85rem] font-bold tracking-wider uppercase text-tac-orange hover:text-white transition-colors">
              decouvrir les offres &rarr;
            </a>
          </div>
        </div>

        <!-- Institutions -->
        <div class="group reveal-up opacity-0 border border-white/10 bg-black/30 backdrop-blur-sm overflow-hidden transition-all duration-500 hover:border-tac-orange/50" style="--delay: 0.3s;">
          <div class="relative overflow-hidden">
            <img src="/images/escape-game-toulouse-institution.webp" alt="Jeunes s'amusant dans l'Escape Game Sensoriel" class="w-full aspect-[3/2] object-cover transition-transform duration-700 group-hover:scale-105 brightness-90" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <h3 class="absolute bottom-4 left-5 right-5 font-share text-[1.1rem] font-bold text-white leading-tight">Institutions, associations, scolaires</h3>
          </div>
          <div class="p-5">
            <p class="font-mulish text-[0.8rem] font-semibold leading-normal text-white/65 mb-4">Une activite divertissante et immersive qui plaira surement a tous.</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <a href="/institutions-jeunesse-toulouse/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">Jeunesse</a>
              <a href="/escape-game-sortie-scolaire/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">Scolaires</a>
              <a href="/escape-game-integration-bde/" class="btn-tag !text-[0.8rem] !py-1.5 !px-3.5 !tracking-normal">Etudiants</a>
            </div>
            <a href="/institutions-jeunesse-toulouse/" class="inline-block font-share text-[0.85rem] font-bold tracking-wider uppercase text-tac-orange hover:text-white transition-colors">
              decouvrir les offres &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spacer -->
  <div class="h-20 lg:h-32 bg-tac-black"></div>

  <!-- ==================== AVIS ==================== -->
  <section class="relative overflow-hidden bg-tac-dark-blue">

    <div class="relative z-10 section-content pt-40 lg:pt-52 pb-20 lg:pb-28">
      <div class="flex items-center gap-4 mb-10 reveal-left opacity-0">
        <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Escape Game Toulouse avis" class="w-[42px] h-[43px] shrink-0" />
        <h2 class="font-share text-large lg:text-larger font-bold tracking-[-2px] leading-none">
          <span class="text-white">Les </span>
          <span class="text-tac-orange">Avis</span>
        </h2>
      </div>

      <!-- Platform reviews -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
        <!-- TripAdvisor -->
        <div class="review-card bg-white text-black p-7 lg:p-8 flex flex-col justify-between reveal-up opacity-0 transition-all duration-500 hover:-translate-y-1 hover:shadow-xl hover:shadow-tac-orange/10" style="--delay: 0.1s;">
          <ul class="list-none pl-0 mb-5 space-y-2.5">
            <li class="text-sm italic leading-relaxed pl-4 border-l-2 border-tac-orange/30">Super Escape Game, surprenant et ludique</li>
            <li class="text-sm italic leading-relaxed pl-4 border-l-2 border-tac-orange/30">Un moment génial en famille !</li>
            <li class="text-sm italic leading-relaxed pl-4 border-l-2 border-tac-orange/30">Team Building réussi !</li>
            <li class="text-sm italic leading-relaxed pl-4 border-l-2 border-tac-orange/30">Les 5 sens hors du temps</li>
            <li class="text-sm italic leading-relaxed pl-4 border-l-2 border-tac-orange/30">Juste génial !</li>
            <li class="text-sm italic leading-relaxed pl-4 border-l-2 border-tac-orange/30">Excellente activité d'EVJF</li>
          </ul>
          <div class="border-t-2 border-tac-orange pt-5 text-center">
            <img src="/images/tactisens-tripadvisor.webp" alt="Tactisens Escape Game Toulouse Avis Tripadvisor" class="h-[55px] mx-auto" />
          </div>
        </div>

        <!-- Google -->
