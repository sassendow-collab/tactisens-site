---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Escape Game Toulouse. Jeu d'evasion Sensoriel | Tactisens">

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[100dvh] flex items-center justify-center text-center overflow-hidden">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline
      poster="/images/escape-game-toulouse-tactisens-01.webp"
    >
      <source src="/images/1060140731-sd.mov" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-tac-dark-blue/80 via-black/50 to-black/0"></div>
    <div class="relative z-10 px-5 max-w-[1420px] mx-auto">
      <img src="/images/escape-game-toulouse-tactisens.webp" alt="Icônes des sens du logo Tactisens Escape Game Toulouse" class="w-[170px] h-[170px] mx-auto mb-12" />
      <h1 class="font-share text-bigger lg:text-colossal font-normal text-[#b6b3b3] uppercase tracking-wide mb-5">
        Escape Game Toulouse
      </h1>
      <h2 class="font-share text-colossal lg:text-gigantic font-bold text-white leading-none tracking-[-3px] mb-16">
        Vivez une aventure <br>captivante et unique !
      </h2>
      <a href="/reservation/" class="btn-outline-white">réservez votre aventure !</a>
    </div>
  </section>

  <!-- ==================== STATS BAR ==================== -->
  <section class="bg-tac-black py-12 lg:py-16">
    <div class="section-content">
      <p class="text-center text-big lg:text-bigger font-normal leading-relaxed max-w-[690px] mx-auto mb-10">
        Plus qu'un Escape Game, un&nbsp;divertissement&nbsp;original&nbsp;à&nbsp;partager<br>entre amis, entre collègues, en famille.
      </p>
      <div class="grid grid-cols-2 lg:grid-cols-4 text-center">
        <div class="py-5 px-4 border-r border-white/20">
          <img src="/images/escape-game-toulouse-tactisens-15.webp" alt="Escape Game Toulouse âge minimum" class="w-[50px] h-[54px] mx-auto mb-5" />
          <p class="font-share text-big font-normal leading-tight">de</p>
          <p class="font-share text-bigger font-normal leading-tight">7 à 97 ans</p>
        </div>
        <div class="py-5 px-4 lg:border-r border-white/20">
          <img src="/images/escape-game-toulouse-tactisens-16.webp" alt="Escape Game Toulouse, participants maximums" class="w-[56px] h-[54px] mx-auto mb-5" />
          <p class="font-share text-big font-normal leading-tight">de</p>
          <p class="font-share text-bigger font-normal leading-tight whitespace-nowrap">2 à 72 joueurs</p>
        </div>
        <div class="py-5 px-4 border-r border-white/20">
          <img src="/images/escape-game-toulouse-tactisens-18.webp" alt="Escape Game Toulouse, prix tarifs" class="w-[56px] h-[54px] mx-auto mb-5" />
          <p class="font-share text-big font-normal leading-tight">à partir de</p>
          <p class="font-share text-bigger font-normal leading-tight whitespace-nowrap">29 &euro;</p>
        </div>
        <div class="py-5 px-4">
          <img src="/images/escape-game-toulouse-tactisens-17.webp" alt="Escape Game Toulouse, recommandations Tripadvisor" class="w-[73px] h-[54px] mx-auto mb-5" />
          <p class="font-share text-big font-normal leading-tight">Travellers'</p>
          <p class="font-share text-bigger font-normal leading-tight">Choice</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== MISSIONS ==================== -->
  <section class="relative bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/escape-game-toulouse-tactisens-03.webp');">
    <div class="section-content py-20">
      <div class="flex items-center gap-5 mb-10">
        <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Escape Game Toulouse les missions" class="w-[49px] h-[50px] shrink-0" />
        <h2 class="font-share text-larger lg:text-colossal font-bold tracking-[-3px] leading-none">
          <span class="text-white">Les </span>
          <span class="text-tac-orange">missions</span>
        </h2>
      </div>
      <p class="font-mulish text-bigger font-normal leading-relaxed mb-20 max-w-[900px]">
        Tactisens Escape Game Toulouse vous propose des Escape Room originaux, funs et immersifs pour vous faire vivre un moment palpitant et unique&nbsp;!
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20">
        <!-- L'AVENTURE SENSORIELLE -->
        <div class="border border-tac-orange bg-black/50 p-8 lg:p-10 max-w-[670px]">
          <h3 class="font-share text-larger font-normal leading-none mb-2">L'AVENTURE SENSORIELLE</h3>
          <p class="font-share text-body uppercase opacity-80 mb-8">un défi lancé à vos sens</p>
          <img src="/images/Laventure-sensorielle-Escape-game-a-Toulouse.png" alt="" class="w-full mb-2 aspect-[4/3] object-cover" />
          <hr class="separator-orange my-5" />
          <div class="flex flex-wrap justify-between items-center gap-4 text-sm">
            <div class="flex items-center gap-2">
              <img src="/images/escape-game-toulouse-tactisens-16.webp" alt="Escape Game Toulouse, participants maximums" class="w-10 h-10" />
              <span class="font-mulish font-semibold leading-tight">3 à 12<br>joueurs </span>
            </div>
            <div class="flex items-center gap-2">
              <img src="/images/escape-game-toulouse-tactisens-19.webp" alt="Escape Game Toulouse durée" class="w-10 h-10" />
              <span class="font-mulish font-semibold leading-tight">60 <br>minutes</span>
            </div>
            <div class="flex items-center gap-2">
              <img src="/images/escape-game-toulouse-tactisens-15.webp" alt="Escape Game Toulouse âge minimum" class="w-10 h-10" />
              <span class="font-mulish font-semibold leading-tight">de 7 à 97<br>ans</span>
            </div>
          </div>
          <hr class="separator-orange my-5" />
          <div class="flex flex-wrap items-center gap-3 text-sm mb-2">
            <span class="font-share font-bold text-tac-orange uppercase tracking-wider">niveau de difficulté :</span>
            <span class="flex items-center gap-1 font-mulish font-semibold">
              <img src="/images/true.svg" alt="" class="w-3 h-3" />
              Adapaté aux familles
            </span>
            <span class="flex items-center gap-1 font-mulish font-semibold">
              <img src="/images/true.svg" alt="" class="w-3 h-3" />
              Adaptable selon le niveau des joueurs
            </span>
          </div>
          <hr class="separator-orange my-5" />
          <p class="font-mulish text-sm font-semibold leading-relaxed mb-8">Vous serez les cobayes du protocole de test sur les sens élaboré par le Dr Windar.<br><br>Dans des situations insolites et amusantes, vos 5 sens seront les héros de ce périple inédit : la vue, le toucher, le goût, l'ouïe et l'odorat seront mis à rude épreuve.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/reservation/" class="btn-orange flex-1 min-w-[200px] text-center">réserver</a>
            <a href="/mission/escape-game-original-aventure-sensorielle/" class="btn-outline-orange flex-1 min-w-[200px] text-center">en savoir plus</a>
          </div>
        </div>

        <!-- THE BUNKER -->
        <div class="border border-tac-orange bg-black/50 p-8 lg:p-10 max-w-[670px]">
          <h3 class="font-share text-larger font-normal leading-none mb-2">THE BUNKER</h3>
          <p class="font-share text-body uppercase opacity-80 mb-8">escape room</p>
          <img src="/images/The-Bunker-Escape-game-a-Toulouse.png" alt="" class="w-full mb-2 aspect-[4/3] object-cover" />
          <hr class="separator-orange my-5" />
          <div class="flex flex-wrap justify-between items-center gap-4 text-sm">
            <div class="flex items-center gap-2">
              <img src="/images/escape-game-toulouse-tactisens-16.webp" alt="Escape Game Toulouse, participants maximums" class="w-10 h-10" />
              <span class="font-mulish font-semibold leading-tight">2 à 6 joueurs</span>
            </div>
            <div class="flex items-center gap-2">
              <img src="/images/escape-game-toulouse-tactisens-19.webp" alt="Escape Game Toulouse durée" class="w-10 h-10" />
              <span class="font-mulish font-semibold leading-tight">60<br>minutes</span>
            </div>
            <div class="flex items-center gap-2">
              <img src="/images/escape-game-toulouse-tactisens-15.webp" alt="Escape Game Toulouse âge minimum" class="w-10 h-10" />
              <span class="font-mulish font-semibold leading-tight">de 10 à 97<br>ans</span>
            </div>
          </div>
          <hr class="separator-orange my-5" />
          <div class="flex flex-wrap items-center gap-3 text-sm mb-2">
            <span class="font-share font-bold text-tac-orange uppercase tracking-wider">niveau de difficulté :</span>
            <span class="flex items-center gap-1 font-mulish font-semibold">
              <img src="/images/true.svg" alt="" class="w-3 h-3" />
              6/10
            </span>
            <span class="flex items-center gap-1 font-mulish font-semibold">
              <img src="/images/true.svg" alt="" class="w-3 h-3" />
              Adaptable selon le niveau des joueurs
            </span>
          </div>
          <hr class="separator-orange my-5" />
          <p class="font-mulish text-sm font-semibold leading-relaxed mb-8">Oserez-vous pénétrer dans le bunker désaffecté où s'est réfugié le Dr Windar pour protéger ses recherches sur la vie éternelle ? <br><br><br>Déjouez les pièges, retrouvez les pistes et récupérez ses recherches pour sauver l'humanité. Adrénaline, amusement et sollicitation cérébrale.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/reservation/" class="btn-orange flex-1 min-w-[200px] text-center">réserver</a>
            <a href="/mission/escape-room-toulouse/" class="btn-outline-orange flex-1 min-w-[200px] text-center">en savoir plus</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== VIDEO CTA ==================== -->
  <section class="bg-tac-black py-20 lg:py-28">
    <div class="section-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="relative pb-[56.25%] h-0 overflow-hidden rounded-lg">
          <iframe class="absolute top-0 left-0 w-full h-full" src="https://www.youtube.com/embed/8s0mPKsrfKA" title="Tactisens Escape Game Toulouse" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="lg:pl-16">
          <div class="flex items-start gap-5">
            <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Tactisens Escape Game Toulouse" class="w-[49px] h-[50px] shrink-0" />
            <h2 class="font-share text-larger lg:text-colossal font-bold tracking-[-3px] leading-none">
              <span class="text-white">Tactisens </span><br />
              <span class="text-white">Escape Game Toulouse :</span> <br />
              <span class="text-tac-orange">Quel sera votre défi ?</span>
            </h2>
          </div>
        </div>
      </div>
      <div class="text-center mt-16">
        <a href="/reservation/" class="btn-outline-orange px-16">Réservez votre aventure !</a>
      </div>
    </div>
  </section>

  <!-- ==================== EVENEMENTS ==================== -->
  <section class="relative bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/escape-game-toulouse-tactisens-05.webp');">
    <div class="section-content py-20 lg:py-28">
      <div class="flex items-start gap-5 mb-20">
        <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Tactisens Escape Game Toulouse évènements" class="w-[49px] h-[50px] shrink-0" />
        <h2 class="font-share text-larger lg:text-colossal font-bold tracking-[-3px] leading-none">
          <span class="text-white">Tactisens pour vos <br></span>
          <span class="text-tac-orange">évènements à Toulouse</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12">

        <!-- Entreprises -->
        <div>
          <img src="/images/escape-game-toulouse-team-building.webp" alt="Team building à Tactisens Escape Game Toulouse" class="w-full mb-5" />
          <h3 class="font-share text-large font-bold text-tac-orange leading-tight mb-5 pb-5">Escape Game pour Entreprises à&nbsp;Toulouse</h3>
          <p class="font-mulish text-sm font-semibold leading-normal text-[#ebebeb] mb-5">Tactisens Escape Game Toulouse propose une série de prestations pensées pour une sortie d'entreprise réussie. Cohésion d'équipe avec des activités ludiques au top. <a href="/location-de-salle-a-toulouse/" class="text-tac-orange underline">Salle de réunion et réception</a>. Cocktails déjeunatoires ou dînatoires, et plus encore&nbsp;!</p>
          <div class="flex flex-col gap-2 mb-6">
            <a href="/evenement/entreprises/" class="btn-tag w-fit">Team building</a>
            <a href="/escape-game-recrutement/" class="btn-tag w-fit">Recrutement</a>
            <a href="/escape-game-ce-cse/" class="btn-tag w-fit">Comité d'entreprise</a>
          </div>
          <a href="/evenement/entreprises/" class="font-share text-big font-bold tracking-wider uppercase text-white underline underline-offset-4 hover:text-tac-orange">
            découvrir toutes les offres
          </a>
        </div>

        <!-- Particuliers -->
        <div>
          <img src="/images/escape-game-toulouse-particuliers.webp" alt="Escape Game à Toulouse équipe Tactisens" class="w-full mb-5" />
          <h3 class="font-share text-large font-bold text-tac-orange leading-tight mb-5 pb-5">Escape Game pour particuliers à Toulouse</h3>
          <p class="font-mulish text-sm font-semibold leading-normal text-[#ebebeb] mb-5">Pour tous vos événements entre amis ou en famille, Tactisens Escape Game Toulouse vous permet de passer un moment amusant dans une ambiance originale et décalée. Plus qu'un Escape Game, une sortie à Toulouse à ne pas rater !</p>
          <div class="flex flex-col gap-2 mb-6">
            <a href="/evjf-toulouse/" class="btn-tag w-fit">EVJF</a>
            <a href="/evg-toulouse/" class="btn-tag w-fit">EVG</a>
            <a href="/anniversaire-original-toulouse/" class="btn-tag w-fit">Anniversaire</a>
          </div>
          <a href="/evenement/particuliers/" class="font-share text-big font-bold tracking-wider uppercase text-white underline underline-offset-4 hover:text-tac-orange">
            découvrir toutes les offres
          </a>
        </div>

        <!-- Institutions -->
        <div>
          <img src="/images/escape-game-toulouse-institution.webp" alt="Jeunes s'amusant dans l'Escape Game Sensoriel" class="w-full mb-5" />
          <h3 class="font-share text-large font-bold text-tac-orange leading-tight mb-5 pb-5">Institutions, associations, scolaires....</h3>
          <p class="font-mulish text-sm font-semibold leading-normal text-[#ebebeb] mb-5">Pour une sortie, pour s'amuser, pour partager un bon moment à plusieurs, pensez à Tactisens Escape Game Toulouse&nbsp;! Vous trouverez ce qu'il vous faut pour proposer une activité divertissante et immersive qui plaira sûrement à tous.</p>
          <div class="flex flex-col gap-2 mb-6">
            <a href="/institutions-jeunesse-toulouse/" class="btn-tag w-fit">Jeunesse</a>
            <a href="/escape-game-sortie-scolaire/" class="btn-tag w-fit">Scolaires</a>
            <a href="/escape-game-integration-bde/" class="btn-tag w-fit">Associations étudiantes</a>
          </div>
          <a href="/institutions-jeunesse-toulouse/" class="font-share text-big font-bold tracking-wider uppercase text-white underline underline-offset-4 hover:text-tac-orange">
            découvrir toutes les offres
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ==================== AVIS ==================== -->
  <section class="relative">
    <div class="bg-fixed bg-cover bg-center" style="background-image: url('/images/escape-game-toulouse-tactisens-02.webp');">
      <div class="bg-[#f050240f] py-20 lg:py-28">
        <div class="section-content">
          <div class="flex items-center gap-5 mb-8">
            <img src="/images/escape-game-toulouse-tactisens-31.webp" alt="Escape Game Toulouse avis" class="w-[49px] h-[50px] shrink-0" />
            <h2 class="font-share text-larger lg:text-colossal font-bold tracking-[-3px] leading-none">
              <span class="text-white">Les </span>
              <span class="text-tac-orange">Avis</span>
            </h2>
          </div>

          <!-- Reviews cards -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
            <!-- TripAdvisor -->
            <div class="bg-white text-black p-8 lg:p-10 flex flex-col justify-between min-h-[286px]">
              <ul class="list-disc pl-5 mb-5 space-y-1">
                <li class="text-sm italic leading-relaxed">Super Escape Game, surprenant et ludique</li>
                <li class="text-sm italic leading-relaxed">Un moment génial en famille !</li>
                <li class="text-sm italic leading-relaxed">Team Building réussi !</li>
                <li class="text-sm italic leading-relaxed">Les 5 sens hors du temps</li>
                <li class="text-sm italic leading-relaxed">Juste génial !</li>
                <li class="text-sm italic leading-relaxed">Excellente activité d'EVJF</li>
              </ul>
              <div class="border-t-2 border-tac-orange pt-5 text-center">
                <img src="/images/tactisens-tripadvisor.webp" alt="Tactisens Escape Game Toulouse Avis Tripadvisor" class="h-[60px] mx-auto" />
              </div>
            </div>

            <!-- Google -->
            <div class="bg-white text-black p-8 lg:p-10 flex flex-col justify-between min-h-[286px]">
              <ul class="list-disc pl-5 mb-5 space-y-1">
                <li class="text-sm italic leading-relaxed">Inventif, sympathique et rigolo</li>
                <li class="text-sm italic leading-relaxed">Un merveilleux moment</li>
                <li class="text-sm italic leading-relaxed"><strong>Superbe expérience pour l'escape game !</strong></li>
                <li class="text-sm italic leading-relaxed">Très belle découverte.</li>
                <li class="text-sm italic leading-relaxed"><strong>Aventure en famille (de 10 à 70 ans)</strong></li>
                <li class="text-sm italic leading-relaxed"> Super activité afterwork !</li>
              </ul>
              <div class="border-t-2 border-tac-orange pt-5 text-center">
                <img src="/images/tactisens-google.webp" alt="Tactisens Escape Game Toulouse Avis Google" class="h-[60px] mx-auto" />
              </div>
            </div>

            <!-- Facebook -->
            <div class="bg-white text-black p-8 lg:p-10 flex flex-col justify-between min-h-[286px]">
              <ul class="list-disc pl-5 mb-5 space-y-1">
                <li class="text-sm italic leading-relaxed">Escape game extraordinaire</li>
                <li class="text-sm italic leading-relaxed"><strong>Super moment et très belle découverte</strong></li>
                <li class="text-sm italic leading-relaxed">Un excellent moment ludique !</li>
                <li class="text-sm italic leading-relaxed"><strong>Allez y sans hésiter ! Fous rires assurés</strong></li>
                <li class="text-sm italic leading-relaxed">Activité très sympa pour un EVJF</li>
                <li class="text-sm italic leading-relaxed">A faire absolument ! Inventif, créatif…</li>
              </ul>
              <div class="border-t-2 border-tac-orange pt-5 text-center">
                <img src="/images/tactisens-facebook.webp" alt="Tactisens Escape Game Toulouse Avis Facebook" class="h-[60px] mx-auto" />
              </div>
            </div>
          </div>

          <!-- Testimonials -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
            <div class="bg-white text-black p-8 lg:p-10">
              <img src="/images/escape-game-toulouse-entreprise.webp" alt="Escape Game Toulouse Team Building Entreprise" class="w-full rounded mb-5" />
              <p class="text-sm italic leading-relaxed mt-5">Merci à l'équipe Tactisens pour leur accueil et de nous avoir fait vivre une super Aventure Sensorielle. Bonne humeur et esprit d'équipe sont au rendez-vous.</p>
              <hr class="separator-orange my-5" />
              <p class="text-sm font-normal uppercase">L'équipe Génération, Ambicita et 2CS </p>
            </div>
            <div class="bg-white text-black p-8 lg:p-10">
              <img src="/images/escape-game-toulouse-sens.webp" alt="Escape Game Sensoriel à Toulouse" class="w-full rounded mb-5" />
              <p class="text-sm italic leading-relaxed mt-5">Excellent moment en famille. Super accueil. <br>Des énigmes bien conçues, une ambiance différente d'un escape game classique.</p>
              <hr class="separator-orange my-5" />
              <p class="text-sm font-normal uppercase">Simon B.</p>
            </div>
            <div class="bg-white text-black p-8 lg:p-10">
              <img src="/images/escape-game-toulouse-evjf.webp" alt="Tactisens Escape Game Toulouse EVJF Original" class="w-full rounded mb-5" />
              <p class="text-sm italic leading-relaxed mt-5">On a essayé l'Aventure Sensorielle pour un EVJF. On a beaucoup apprécié l'activité qui change des escape game classiques.<br>Le « maître du jeu » était au top !</p>
              <hr class="separator-orange my-5" />
              <p class="text-sm font-normal uppercase">Syndie G.</p>
            </div>
          </div>

          <!-- Presse -->
          <h3 class="font-share text-2xl font-semibold mt-12 mb-8">Ils parlent de nous</h3>
          <div class="flex flex-wrap items-center gap-5 mb-4">
            <img src="/images/escape-game-toulouse-20-minutes.webp" alt="Escape Game à Toulouse, 20 Minutes" class="h-10 opacity-90" />
            <img src="/images/escape-game-toulouse-le-parisien.webp" alt="Escape Game à Toulouse, Le Parisien" class="h-10 opacity-90" />
            <img src="/images/escape-game-toulouse-fr3-occitanie.webp" alt="Escape Game à Toulouse, FR3 occitanie" class="h-10 opacity-90" />
            <img src="/images/escape-game-toulouse-le-bonbon.webp" alt="Escape Game à Toulouse, Le Bonbon" class="h-10 opacity-90" />
            <img src="/images/escape-game-toulouse-le-journal-toulousain.webp" alt="Escape Game à Toulouse, Le Journal Toulousain" class="h-10 opacity-90" />
          </div>
          <div class="flex flex-wrap items-center gap-5">
            <img src="/images/escape-game-toulouse-actu-touiouse.webp" alt="Escape Game à Toulouse, actu point fr" class="h-10 opacity-90" />
            <img src="/images/escape-game-toulouse-viaoccitanie.webp" alt="Escape Game à Toulouse, viàOccitanie" class="h-10 opacity-90" />
