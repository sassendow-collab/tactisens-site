---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Presse | Tactisens Escape Game Toulouse" description="Tactisens dans les medias. Decouvrez les articles de presse et reportages sur notre escape game a Toulouse.">

  <!-- ==================== HERO COMPACT ==================== -->
  <section class="relative min-h-[250px] flex items-end">
    <div class="absolute inset-0">
      <img
        src="/images/escape-game-toulouse-tactisens-04.webp"
        alt="Escape Game Toulouse Tactisens Presse"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="section-content relative z-10 py-10 w-full">
      <h1 class="font-share text-larger lg:text-colossal font-bold leading-none">Presse</h1>
      <nav class="text-sm mt-3 text-white/70" aria-label="Breadcrumb">
        <a href="/" class="text-white/70 hover:text-white no-underline">Accueil</a>
        <span class="mx-2">/</span>
        <span class="text-white">Presse</span>
      </nav>
    </div>
  </section>

  <!-- ==================== ILS PARLENT DE NOUS ==================== -->
  <section class="bg-tac-dark-blue py-16 lg:py-24">
    <div class="section-content">
      <!-- Spirale + Titre -->
      <div class="flex flex-col items-center mb-12 lg:mb-16">
        <img
          src="/images/escape-game-toulouse-tactisens-31-bis.webp"
          alt=""
          class="w-[60px] h-[60px] object-contain mb-6"
        />
        <h2 class="font-share text-larger lg:text-colossal font-bold text-center leading-none tracking-[-2px]">
          <span class="text-tac-white">Ils parlent</span><br />
          <span class="text-tac-orange">de nous</span>
        </h2>
      </div>

      <!-- Grid logos presse -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-20-minutes.webp" alt="20 Minutes" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-la-depeche-du-midi.webp" alt="La Depeche du Midi" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-france-bleu-occitanie.webp" alt="France Bleu Occitanie" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-fr3-occitanie.webp" alt="France 3 Occitanie" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-le-bonbon.webp" alt="Le Bonbon" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-le-journal-toulousain.webp" alt="Le Journal Toulousain" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-le-parisien.webp" alt="Le Parisien" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-opinion-independante.webp" alt="Opinion Independante" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-actu-touiouse.webp" alt="Actu Toulouse" class="max-h-[60px] object-contain" />
        </div>
        <div class="bg-white p-6 flex items-center justify-center min-h-[120px]">
          <img src="/images/escape-game-toulouse-viaoccitanie.webp" alt="Via Occitanie" class="max-h-[60px] object-contain" />
        </div>
      </div>
    </div>
  </section>

</Layout>
