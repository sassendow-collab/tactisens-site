	.form-field.disp-none {display: none}
	:root {
		--wp--custom--typography--letter-spacing--nagetive: -2px;
	}
	
	.wp-block-outermost-social-sharing {
		
	}
	.wp-block-outermost-social-sharing.is-style-logos-only .outermost-social-sharing-link svg {
    	height: 35px;
    	width: 35px;
	}
	
	ul.ul-check {
		padding-left: 0rem;
		list-style: none;
	}
	
	ul.ul-check li {
		position: relative;
		padding-left: 2rem;
	}

	ul.ul-check li:before {
		content: ' ';
		position: absolute;
		display: inline-block;
		height: 14px;
		width: 13px;
		top: 6px;
		left: 0;
		background: url('https://www.tactisens.com/wp-content/uploads/2023/05/true.svg') no-repeat center;
	}
	
	.wp-block-heading a {
		color: inherit;
	}
	.wp-block-heading a:hover, 
	.wp-block-heading a:focus {
		text-decoration:underline !important;
	}
	
	.slider1 .rr-columns ul {
		min-height: 200px;
	}
	.rr-columns .rr-desc {
    	min-height: 105px !important;
	}
	.reviews-ratings .widget img {
    	height: 100% !important;
	}
	.wp-block-tac-blocks-tac-faq-panel-item {}
	.wp-block-tac-blocks-tac-faq-panel-item .sa-para {
		font-weight: bold; 
	}
	
	.wp-block-tac-blocks-tac-faq-panel-item .sa-wrapper {
		padding: 14px 15px;
	}
	
	.wp-block-tac-blocks-tac-faq-panel-item .sa-wrapper .top-wrapper .sa-heading h5 {
		font-size: 15px !important;
	}
	
	.wp-block-tac-blocks-tac-faq-panel-item .sa-wrapper .sa-para p {
		font-size: 14px;
	}
	
	@media only screen and (min-width: 960px) {
		html { scroll-padding-top: 120px } 
	}
	
	@media only screen and (max-width: 781px) {
		.wp-block-cover .wp-block-embed {
			min-width: 1px;
			width: 100%;
			max-width: 100%;
		}
		h1.wp-block-heading {
			font-size: 29px;
		}
		
		.spiral_img {
			width: 42px !important;
			flex-basis: 42px;
		}	
		
		.spiral_img img[src$=".svg"] {
			width: 100% !important;
		}
		
		.they-trusted-us h2.wp-block-heading,
		.pursue-the-tactisens h2.wp-block-heading,
		.lir-text h3.wp-block-heading,
		.sensory-adventure-rates h2.wp-block-heading,
		.escape-game-concept h2.wp-block-heading,
		.wp-block-tac-blocks-tac-faq-panel h2.wp-block-heading,
		.escape-room-toulouse h2.wp-block-heading,
		.embedded-video-cta h2.wp-block-heading,
		.events-listing h2.wp-block-heading { 
			padding-left: 20px !important;
		}
		
		.events-listing .buttons-row {
    		flex-direction: initial !important;
		}
		
		.wp-block-group .reviews-ratings-head {
			justify-content: start;
			align-items:center; 
		}
		
		.reviews-ratings .reviews-ratings-head {
			margin-bottom: 0px !important;
		}
		
	.sa-wrapper .top-wrapper .sa-heading h5 {
	    font-size: 17px !important;
    	line-height: normal !important;		
	}
	.wp-block-tac-blocks-tac-faq-panel-item .sa-para p {
		font-size: 13px;
	}
		
	.rr-columns .rr-desc,
	.slider1 .rr-columns ul {
    	min-height: 1px !important;
	}
	.pursue-the-tactisens h2.wp-block-heading {
	    font-size: 17px !important;
    	padding-left: 0 !important;		
	}
	.escape-game-concept-unique h2.wp-block-heading {
	    margin-top: 0 !important;		
	}
		
	}
