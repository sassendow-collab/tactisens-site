body.page-id-26435 {
    background-image: url('https://www.tactisens.com/wp-content/uploads/2025/05/pattern-background-page-reservation-bleu.webp');
    background-repeat: repeat;
    background-size: 200px 200px; /* adapte la taille si besoin */
    background-position: top left;
