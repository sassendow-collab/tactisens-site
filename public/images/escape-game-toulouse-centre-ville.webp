.transparentbtn a.has-background {
		background-color: inherit;
}
.spiral_img img {
	min-width: 49px;
}
.single-post .wp-block-group h1, .single-post .wp-block-group h2 {
	text-transform: none;
}

#theme-breadcrumbs .separator {
	color: #FFF;
}

.single-post .entry-content .wp-block-group p:last-child {
	margin-bottom: 0;
}

.single-post .entry-content .wp-block-heading {
	margin: 2rem 0;
}

.carrousel-partenaires div div {
	   display: flex;
    align-items: center;
    justify-content: center;
}

.bloc-flex {
	display: flex;
    flex-direction: column;
    justify-content: space-between;
}

@media only screen and (max-width: 768px) {
	h5 {
		max-width: 300px;
	}
}

